import math
import numpy as np
import unittest
from scipy.spatial.transform import Rotation
import cuvslam as vslam
from cuvslam import refinement

# Constants matching C++ test
TRANSLATION_NOISE = 0.15
ROTATION_NOISE = 0.02
POINT_NOISE = 0.15
INTRINSICS_NOISE = 3.0


def generate_equidistant_grid_points(num_points_per_axis: int, cube_size: float):
    """Generates a grid of 3D points in a cube centered at origin."""
    step = cube_size / (num_points_per_axis - 1)
    half_cube_size = cube_size / 2.0

    points = []
    for x in range(num_points_per_axis):
        for y in range(num_points_per_axis):
            for z in range(num_points_per_axis):
                points.append([
                    x * step - half_cube_size,
                    y * step - half_cube_size,
                    z * step - half_cube_size
                ])
    return np.array(points)


def generate_circular_motion_poses(problem: refinement.BundleAdjustmentProblem,
                                   num_cameras: int, radius: float):
    """Generates poses for cameras in a circular motion around origin."""
    poses = {}
    for i in range(num_cameras):
        angle = 2 * math.pi * i / num_cameras
        # Create rotation matrix around z-axis
        axis_of_rotation = np.array([math.cos(angle), math.sin(angle), 0])
        translation = np.array([
            math.cos(angle) * radius,
            math.sin(angle) * radius,
            math.cos(angle) * radius
        ])
        # Create rotation as quaternion (in xyzw order, matching both scipy and vslam.Pose)
        rotation = Rotation.from_rotvec(angle * axis_of_rotation).as_quat()

        pose = vslam.Pose()
        pose.rotation = rotation
        pose.translation = translation
        poses[i] = pose
    # TODO: directly append poses to problem.world_from_rigs
    problem.world_from_rigs = poses


def project_points_to_cameras(problem: refinement.BundleAdjustmentProblem,
                              points_3d: np.ndarray,
                              num_cameras: int):
    """Projects 3D points to each camera view."""
    all_observations = {}
    for i in range(num_cameras):
        observations = []

        for j, point in enumerate(points_3d):
            # Transform point from world to camera coordinates
            # Use scipy Rotation directly with the quaternion
            quat = np.array(problem.world_from_rigs[i].rotation)
            rot = Rotation.from_quat(quat)
            t = np.array(problem.world_from_rigs[i].translation)
            # Apply rotation and translation
            point_camera = rot.as_matrix() @ point + t

            # Only include points in front of camera
            if point_camera[2] <= 0.0:
                continue

            # Project to normalized image coordinates
            x = point_camera[0] / point_camera[2]
            y = point_camera[1] / point_camera[2]

            # Apply pinhole camera model
            fx = problem.rig.cameras[0].focal[0]
            fy = problem.rig.cameras[0].focal[1]
            cx = problem.rig.cameras[0].principal[0]
            cy = problem.rig.cameras[0].principal[1]

            u = fx * x + cx
            v = fy * y + cy

            # Don't include points outside image
            if (u <= 0 or u >= problem.rig.cameras[0].size[0] or
                    v <= 0 or v >= problem.rig.cameras[0].size[1]):
                continue

            observation = vslam.Observation()
            observation.id = j
            observation.u = u
            observation.v = v
            observation.camera_index = 0

            observations.append(observation)

        all_observations[i] = observations
    # TODO: directly assign observations to problem.observations
    problem.observations = all_observations


def remove_unseen_points(problem: refinement.BundleAdjustmentProblem,
                         points_3d: np.ndarray,
                         num_cameras: int):
    """Removes points not seen by any camera."""
    seen_points = set()
    points_in_world = problem.points_in_world

    for i in range(num_cameras):
        for obs in problem.observations[i]:
            seen_points.add(obs.id)

    # Remove points not seen by any camera
    for i in range(len(points_3d)):
        if i not in seen_points:
            if i in points_in_world:
                del points_in_world[i]
    # TODO: directly modify problem.points_in_world
    problem.points_in_world = points_in_world


def initialize_bundle_adjustment_problem(num_points: int,
                                         num_cameras: int,
                                         cube_size: float,
                                         radius: float):
    """Creates and initializes a bundle adjustment problem."""
    problem = refinement.BundleAdjustmentProblem()

    # Add camera
    camera = vslam.Camera()
    camera.size = np.array([640, 480])
    camera.focal = np.array([500.0, 510.0])
    camera.principal = np.array([320.0, 240.0])
    problem.rig.cameras = [camera]

    # Fix first two frames
    problem.fixed_frames = [0, 1]

    # Generate 3D points
    points_3d = generate_equidistant_grid_points(num_points, cube_size)
    landmarks = {}
    for i, point in enumerate(points_3d):
        landmark = vslam.Landmark()
        landmark.id = i
        landmark.coords = point
        landmarks[i] = landmark
        # problem.points_in_world[i] = landmark
    # TODO: directly assign landmarks to problem.points_in_world
    problem.points_in_world = landmarks

    generate_circular_motion_poses(problem, num_cameras, radius)
    project_points_to_cameras(problem, points_3d, num_cameras)
    remove_unseen_points(problem, points_3d, num_cameras)

    # Fix points seen by first camera
    problem.fixed_points = [obs.id for obs in problem.observations[0]]

    return problem


def add_random_noise(problem: refinement.BundleAdjustmentProblem):
    """Adds random noise to poses, points and intrinsics."""
    perturbed = refinement.BundleAdjustmentProblem()
    perturbed.rig = problem.rig
    perturbed.points_in_world = problem.points_in_world.copy()
    perturbed.world_from_rigs = problem.world_from_rigs.copy()
    perturbed.observations = problem.observations.copy()
    perturbed.fixed_points = problem.fixed_points.copy()
    perturbed.fixed_frames = problem.fixed_frames.copy()

    # Add noise to poses
    for frame_id, pose in perturbed.world_from_rigs.items():
        if frame_id in perturbed.fixed_frames:
            continue

        # Add noise to rotation and translation
        pose.translation += TRANSLATION_NOISE * (np.random.rand(3) - 0.5)
        # TODO: Add rotation noise

    # Add noise to points
    for point_id, point in perturbed.points_in_world.items():
        if point_id in perturbed.fixed_points:
            continue
        point.coords += POINT_NOISE * (np.random.rand(3) - 0.5)

    # Add noise to intrinsics
    perturbed.rig.cameras[0].focal += INTRINSICS_NOISE * \
        (np.random.rand(2) - 0.5)
    perturbed.rig.cameras[0].principal += INTRINSICS_NOISE * \
        (np.random.rand(2) - 0.5)

    return perturbed


def compare_problems(original: refinement.BundleAdjustmentProblem,
                     perturbed: refinement.BundleAdjustmentProblem,
                     noise_percent: float):
    """Compares two bundle adjustment problems."""
    for frame_id, pose in perturbed.world_from_rigs.items():
        orig_pose = original.world_from_rigs[frame_id]
        np.testing.assert_allclose(
            pose.translation,
            orig_pose.translation,
            atol=TRANSLATION_NOISE * noise_percent
        )
        np.testing.assert_allclose(
            Rotation.from_quat(pose.rotation).as_matrix(),
            Rotation.from_quat(orig_pose.rotation).as_matrix(),
            atol=ROTATION_NOISE * noise_percent
        )

    for point_id, point in perturbed.points_in_world.items():
        orig_point = original.points_in_world[point_id]
        np.testing.assert_allclose(
            point.coords,
            orig_point.coords,
            atol=POINT_NOISE * noise_percent
        )

    np.testing.assert_allclose(
        perturbed.rig.cameras[0].focal,
        original.rig.cameras[0].focal,
        atol=INTRINSICS_NOISE * noise_percent
    )
    np.testing.assert_allclose(
        perturbed.rig.cameras[0].principal,
        original.rig.cameras[0].principal,
        atol=INTRINSICS_NOISE * noise_percent
    )


class TestRefinement(unittest.TestCase):
    def test_ba_problem(self):
        """Tests refinement with no perturbations."""
        num_points = 15
        num_cameras = 18
        cube_size = 20.0
        radius = 40.0
        noise_percent = 0.01

        problem = initialize_bundle_adjustment_problem(
            num_points, num_cameras, cube_size, radius)
        options = refinement.BundleAdjustmentProblemOptions()
        options.verbose = True
        refined_problem, summary = refinement.refine(problem, options)
        print(summary.brief_report())
        # Using unittest's assertion methods through numpy.testing
        compare_problems(problem, refined_problem, noise_percent)

    def test_ba_problem_perturbed(self):
        """Tests refinement with perturbations."""
        num_points = 15
        num_cameras = 18
        cube_size = 20.0
        radius = 40.0
        noise_percent = 0.75

        problem = initialize_bundle_adjustment_problem(
            num_points, num_cameras, cube_size, radius)
        perturbed = add_random_noise(problem)

        options = refinement.BundleAdjustmentProblemOptions()
        options.verbose = True

        refined_problem, summary = refinement.refine(perturbed, options)
        print(summary.brief_report())

        compare_problems(problem, refined_problem, noise_percent)


if __name__ == '__main__':
    unittest.main()
